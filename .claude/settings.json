{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(dotnet format*)",
      "Bash(dotnet ef*)",
      "Bash(dotnet run*)",
      "Bash(dotnet new*)",
      "Bash(dotnet add*)",
      "Bash(dotnet sln*)",
      "Bash(dotnet restore*)",
      "Bash(dotnet clean*)",
      "Bash(docker compose*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)"
